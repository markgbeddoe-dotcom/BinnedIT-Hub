# ============================================================
# Binned-IT Dashboard Hub — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# Supabase (get from: https://app.supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# App environment
VITE_APP_ENV=development

# Anthropic API Key
# NOTE: For production, this should be in a Vercel Edge Function (server-side only).
# For local development you can set it here but DO NOT expose it in the client bundle.
# ANTHROPIC_API_KEY=sk-ant-...

# Resend API Key — required for payment reminder emails and weekly AI digest emails
# Get from: https://resend.com → API Keys
# Must also be added to Vercel environment variables for production
# RESEND_API_KEY=re_...
