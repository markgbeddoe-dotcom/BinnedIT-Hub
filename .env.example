# ============================================================
# SkipSync — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ---- Browser-visible (must use VITE_ prefix; readable from import.meta.env) ----

# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# App environment
VITE_APP_ENV=development

# Web Push public key (browser-side — used to subscribe in SettingsPage)
# Generate the keypair with: npx web-push generate-vapid-keys --json
VITE_VAPID_PUBLIC_KEY=

# ---- Server-only (no VITE_ prefix; used by `vercel dev` and Vercel Edge Functions) ----

# Supabase server-side
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Anthropic Claude — used by /api/chat
# ANTHROPIC_API_KEY=sk-ant-...

# Web Push server-side — used by /api/push-send
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:mark@binnedit.com.au

# Resend — payment reminder + weekly digest emails
# RESEND_API_KEY=re_...

# ── Xero OAuth Integration ───────────────────────────────────────────────────
# Get from: https://developer.xero.com/myapps → your app → OAuth 2.0 credentials
# Redirect URI must be set to: https://binnedit-hub.vercel.app/api/xero-callback

# Required for OAuth flow and token refresh
XERO_CLIENT_ID=YOUR_XERO_CLIENT_ID
XERO_CLIENT_SECRET=YOUR_XERO_CLIENT_SECRET

# Revenue account code in your Xero chart of accounts (default: 200)
# Change this if your Xero organisation uses a different code for skip bin hire revenue.
XERO_REVENUE_ACCOUNT_CODE=200

# Set to true ONLY when you are ready to push draft invoices into Xero.
# Leave false (default) to create invoices locally without writing to Xero.
XERO_WRITE_ENABLED=false

# ── Vercel Cron Security ─────────────────────────────────────────────────────
# Vercel automatically sets this for cron-triggered requests.
# Add it here for local testing of cron endpoints via vercel dev.
# CRON_SECRET=your_cron_secret_here
